# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=m_application
DATABASE_URL=postgresql://postgres:postgres@db:5432/m_application

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Data Center Runtime
# Keep demo seed disabled outside local demos.
ENABLE_DEMO_SEED=false

# Periodic scraping is executed by the worker-beat service.
ENABLE_PERIODIC_SCRAPE=true
PERIODIC_SCRAPE_INTERVAL_MINUTES=30
PERIODIC_SCRAPE_LIMIT=20
# Leave empty to scrape all platforms with active product URLs.
PERIODIC_SCRAPE_PLATFORM=

# Maintenance closes stale PENDING/RUNNING scrape task records.
MAINTENANCE_INTERVAL_MINUTES=5

# Category sync is optional because it depends on the external JD category page.
ENABLE_PERIODIC_CATEGORY_SYNC=false
PERIODIC_CATEGORY_SYNC_HOURS=24

# S3 Storage (e.g. AWS, Minio)
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=us-east-1
S3_BUCKET_NAME=m-application-storage
S3_ENDPOINT=https://s3.amazonaws.com

# Backend Security
SECRET_KEY=generate_a_strong_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
