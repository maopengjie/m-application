DATA_ENGINE_API_V1_PREFIX="/api/v1"
DATA_ENGINE_APP_NAME="Vben Data Engine"
DATA_ENGINE_DEBUG="false"

# Security (Mandatory: Provide strong, unique secrets in production)
# You can generate a secret using: openssl rand -hex 32
DATA_ENGINE_ACCESS_TOKEN_SECRET="generate-a-strong-secret-here"
DATA_ENGINE_REFRESH_TOKEN_SECRET="generate-another-strong-secret-here"

# Data Layer (MySQL 8)
# Use pymysql driver: mysql+pymysql://user:password@host:port/dbname
DATA_ENGINE_MYSQL_DSN="mysql+pymysql://root:password@127.0.0.1:3306/m_application?charset=utf8mb4"

# Redis
DATA_ENGINE_REDIS_URL="redis://127.0.0.1:6379/0"

# Elasticsearch (optional, enable only when search volume requires it)
DATA_ENGINE_ENABLE_ELASTICSEARCH="false"
DATA_ENGINE_ELASTICSEARCH_URL="http://127.0.0.1:9200"
